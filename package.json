{
  "name": "m5kdev-turbo",
  "private": true,
  "license": "GPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/michalkow/m5kdev.git"
  },
  "homepage": "https://github.com/michalkow/m5kdev#readme",
  "bugs": "https://github.com/michalkow/m5kdev/issues",
  "scripts": {
    "build": "turbo run build",
    "build:packages": "turbo run build --filter='!./apps/**'",
    "docs:build": "pnpm --filter m5kdev-docs build",
    "docs:dev": "pnpm --filter m5kdev-docs dev",
    "docs:serve": "pnpm --filter m5kdev-docs serve",
    "patch:all": "pnpm --filter=@m5kdev/* version:patch",
    "pack:all": "pnpm patch:all && pnpm build:packages && pnpm pack --filter=@m5kdev/*",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "check-types": "turbo run check-types",
    "cs:add": "pnpm dlx @changesets/cli add",
    "cs:patch": "pnpm cs:add --all --patch && pnpm cs:version",
    "cs:publish": "pnpm build && pnpm dlx @changesets/cli publish && git push --follow-tags",
    "cs:version": "pnpm dlx @changesets/cli version",
    "cs:deploy": "read -p 'Message: ' msg && pnpm cs:add -m \"$msg\" && pnpm cs:version && pnpm build && pnpm dlx @changesets/cli publish && git push --follow-tags && git add . && git commit -m \"$msg\" && git push",
    "knip": "knip",
    "test:e2e": "pnpm --filter @starter-app/e2e test:e2e"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@changesets/cli": "catalog:",
    "@types/jest": "catalog:",
    "@types/node": "catalog:",
    "dotenv": "catalog:",
    "jest": "catalog:",
    "knip": "catalog:",
    "ts-jest": "catalog:",
    "tsdown": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "overrides": {
      "resolve": "1.22.10"
    }
  },
  "version": "0.0.1"
}
