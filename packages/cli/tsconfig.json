{
  "$schema": "https://json.schemastore.org/tsconfig",
  "rootDir": ".",
  "compilerOptions": {
    "esModuleInterop": true,
    "importHelpers": true,
    "outDir": "dist",
    "declarationMap": false,
    "emitDeclarationOnly": false,
    "noEmit": false,
    "tsBuildInfoFile": "dist/tsconfig.tsbuildinfo",
    "types": [
      "node",
      "jest"
    ]
  },
  "exclude": [
    "node_modules",
    "dist",
    "tsdown.config.ts"
  ],
  "include": [
    "src/**/*.ts"
  ]
}