{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "rootDir": "./src",
    "esModuleInterop": true,
    "importHelpers": true,
    "outDir": "dist",
    "declarationMap": false,
    "emitDeclarationOnly": false,
    "noEmit": false,
    "tsBuildInfoFile": "dist/tsconfig.tsbuildinfo",
    "types": ["node", "jest"]
  },
  "exclude": ["node_modules", "dist", "tsdown.config.ts", "jest-import-meta-transformer.cjs"],
  "include": ["src/**/*.ts"]
}
