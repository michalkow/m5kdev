{
  "name": "create-m5kdev",
  "version": "0.31.0",
  "license": "GPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/michalkow/m5kdev.git"
  },
  "homepage": "https://github.com/michalkow/m5kdev#readme",
  "bugs": "https://github.com/michalkow/m5kdev/issues",
  "files": [
    "dist",
    "templates"
  ],
  "bin": {
    "create-m5kdev": "dist/src/index.cjs",
    "m5kdev": "dist/src/index.cjs"
  },
  "scripts": {
    "build": "tsx scripts/prepare-templates.ts && tsdown",
    "lint": "biome check src scripts root-templates package.json tsconfig.json jest.config.ts tsdown.config.ts",
    "lint:fix": "biome check src scripts root-templates package.json tsconfig.json jest.config.ts tsdown.config.ts --write",
    "check-types": "tsc --noEmit",
    "test": "jest -c jest.config.ts",
    "test:smoke": "CLI_SMOKE=1 jest -c jest.config.ts src/__tests__/create.smoke.test.ts",
    "prepare:templates": "tsx scripts/prepare-templates.ts"
  },
  "dependencies": {
    "jscodeshift": "catalog:",
    "pacote": "catalog:",
    "semver": "catalog:",
    "tslib": "2.8.1",
    "yaml": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/jscodeshift": "catalog:",
    "@types/pacote": "catalog:",
    "@types/semver": "catalog:",
    "@types/jest": "catalog:",
    "@types/node": "catalog:",
    "jest": "catalog:",
    "ts-jest": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "tsx": "catalog:"
  }
}
