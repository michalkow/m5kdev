{
  "name": "@m5kdev/email",
  "version": "0.16.9",
  "license": "GPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/michalkow/m5kdev.git"
  },
  "homepage": "https://github.com/michalkow/m5kdev#readme",
  "bugs": "https://github.com/michalkow/m5kdev/issues",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "push": "node deploy.js",
    "migrate": "pnpm build && node deploy.js"
  },
  "devDependencies": {
    "dotenv": "catalog:",
    "resend": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "tsx": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "@m5kdev/config": "workspace:*"
  },
  "dependencies": {
    "@react-email/components": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "exports": {
    "./components/*": {
      "import": {
        "types": "./dist/src/components/*.d.mts",
        "default": "./dist/src/components/*.mjs"
      },
      "require": {
        "types": "./dist/src/components/*.d.cts",
        "default": "./dist/src/components/*.cjs"
      }
    },
    "./types": {
      "import": {
        "types": "./dist/src/types.d.mts",
        "default": "./dist/src/types.mjs"
      },
      "require": {
        "types": "./dist/src/types.d.cts",
        "default": "./dist/src/types.cjs"
      }
    }
  }
}
