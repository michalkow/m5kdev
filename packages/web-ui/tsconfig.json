{
  "extends": "@m5kdev/config/tsconfig.vite.json",
  "compilerOptions": {
    "baseUrl": ".",
    "rootDir": ".",
    "outDir": "dist",
    "tsBuildInfoFile": "dist/tsconfig.lib.tsbuildinfo",
    "declarationMap": false,
    "types": [
      "vite/client"
    ],
    "emitDeclarationOnly": false,
    "noEmit": false,
    "allowImportingTsExtensions": false,
  },
  "include": [
    "src"
  ],
  "exclude": [
    "out-tsc",
    "dist",
    "tsdown.config.ts",
    "tests/**/*.spec.ts",
    "tests/**/*.test.ts",
    "tests/**/*.spec.tsx",
    "tests/**/*.test.tsx",
    "tests/**/*.spec.js",
    "tests/**/*.test.js",
    "tests/**/*.spec.jsx",
    "tests/**/*.test.jsx"
  ]
}