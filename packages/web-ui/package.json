    "@radix-ui/react-separator": "catalog:",
    "@radix-ui/react-slider": "catalog:",
    "@radix-ui/react-slot": "catalog:",
    "@radix-ui/react-switch": "catalog:",
    "@radix-ui/react-tabs": "catalog:",
    "@radix-ui/react-toast": "catalog:",
    "@radix-ui/react-tooltip": "catalog:",
    "@tabler/icons-react": "catalog:",
    "@tanstack/react-table": "catalog:",
    "@uiw/color-convert": "catalog:",
    "@uiw/react-color-colorful": "catalog:",
    "class-variance-authority": "catalog:",
    "clsx": "catalog:",
    "cobe": "catalog:",
    "dayjs": "catalog:",
    "chart.js": "catalog:",
    "luxon": "catalog:",
    "dicons": "catalog:",
    "@internationalized/date": "catalog:",
    "framer-motion": "catalog:",
    "lucide-react": "catalog:",
    "motion": "catalog:",
    "next-themes": "catalog:",
    "ogl": "catalog:",
    "nuqs": "catalog:",
    "posthog-js": "catalog:",
    "react": "catalog:",
    "react-big-calendar": "catalog:",
    "react-chartjs-2": "catalog:",
    "react-dom": "catalog:",
    "react-dropzone": "catalog:",
    "react-easy-crop": "catalog:",
    "react-hook-form": "catalog:",
    "react-i18next": "catalog:",
    "react-router": "catalog:",
    "sonner": "catalog:",
    "tailwind-merge": "^3.0.1",
    "tailwindcss-animate": "catalog:",
    "zod": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@trpc/tanstack-react-query": "catalog:"
  },
  "devDependencies": {
    "@m5kdev/backend": "workspace:*",
    "@m5kdev/config": "workspace:*",
    "@m5kdev/commons": "workspace:*",
    "@m5kdev/frontend": "workspace:*",
    "@trpc/server": "catalog:",
    "@types/luxon": "catalog:",
    "@types/react": "catalog:",
    "@types/react-big-calendar": "catalog:",
    "@types/react-dom": "catalog:",
    "globals": "catalog:",
    "vite": "catalog:"
  },
  "exports": {
    "./components/*": {
      "types": "./dist/src/components/*.d.ts",
      "default": "./dist/src/components/*.js"
    },
    "./components/ui/*": {
      "types": "./dist/src/components/ui/*.d.ts",
      "default": "./dist/src/components/ui/*.js"
