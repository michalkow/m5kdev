      "default": "./dist/src/modules/auth/components/*.js"
    },
    "./modules/auth/types": {
      "types": "./dist/src/modules/auth/types.d.ts",
      "default": "./dist/src/modules/auth/types.js"
    },
    "./modules/billing/components/*": {
