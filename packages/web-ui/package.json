    "./components/shared/*": {
      "types": "./dist/src/components/ui/shared/*.d.ts",
      "default": "./dist/src/components/ui/shared/*.js"
    },
    "./animations/*": {
      "types": "./dist/src/animations/*.d.ts",
      "default": "./dist/src/animations/*.js"
