{
  "name": "m5kdev-auth-e2e-expo",
  "version": "1.5.3",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "build": "expo export --platform web --output-dir dist",
    "start": "expo start",
    "dev:standard": "EXPO_PUBLIC_AUTH_E2E_PROFILE=standard EXPO_PUBLIC_SERVER_URL=http://127.0.0.1:18182 EXPO_PUBLIC_APP_URL=http://127.0.0.1:15183 EXPO_NO_TELEMETRY=1 BROWSER=none expo start --web --port 15183 --host localhost",
    "dev:waitlist": "EXPO_PUBLIC_AUTH_E2E_PROFILE=waitlist EXPO_PUBLIC_SERVER_URL=http://127.0.0.1:18183 EXPO_PUBLIC_APP_URL=http://127.0.0.1:15184 EXPO_NO_TELEMETRY=1 BROWSER=none expo start --web --port 15184 --host localhost",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "lint": "biome check app.json package.json metro.config.js eslint.config.js src tsconfig.json uniwind-env.d.ts",
    "lint:fix": "biome check app.json package.json metro.config.js eslint.config.js src tsconfig.json uniwind-env.d.ts --write",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check-types": "tsc --noEmit",
    "typecheck": "pnpm check-types"
  },
  "dependencies": {
    "@expo/metro-runtime": "~56.0.13",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@m5kdev/commons": "workspace:*",
    "@m5kdev/frontend": "workspace:*",
    "@trpc/client": "catalog:",
    "expo": "~56.0.5",
    "expo-constants": "~56.0.16",
    "expo-linking": "~56.0.12",
    "expo-router": "~56.2.7",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "heroui-native": "^1.0.2",
    "m5kdev-auth-e2e-shared": "workspace:*",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.2",
    "react-native-reanimated": "~4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "catalog:",
    "react-native-worklets": "0.8.3",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.1.17",
    "uniwind": "^1.5.0"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@m5kdev/backend": "workspace:*",
    "@m5kdev/config": "workspace:*",
    "@types/react": "~19.2.15",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^56.0.4",
    "prettier": "^3.8.3",
    "typescript": "~6.0.3"
  }
}
